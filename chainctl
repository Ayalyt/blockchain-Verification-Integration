def execute_cipher_verification_cvc5(args):
    service_name = "cipher-verification"
    
    if args.cvc5_file:
        file_path = args.cvc5_file
        if file_path.startswith("./cipher-verification-for-CIRCOM/"):
            file_path = file_path.replace("./cipher-verification-for-CIRCOM/", "/app/", 1)
        elif file_path.startswith("cipher-verification-for-CIRCOM/"):
            file_path = file_path.replace("cipher-verification-for-CIRCOM/", "/app/", 1)
        
        command = ["cvc5", "--stats", file_path]
        return execute_docker_compose_command(service_name, command)
    
    elif args.cvc5_category:
        category = args.cvc5_category
        file_patterns = get_cvc5_file_patterns(category)
        
        if not file_patterns:
            print(f"错误: 未知的类别 '{category}'")
            return False
        
        if not build_container(service_name):
            return False
        
        success = True
        for pattern in file_patterns:
            directory = os.path.dirname(pattern)
            file_ext = os.path.basename(pattern).split('.')[-1]
            
            try:
                result = subprocess.run(
                    ["docker-compose", "run", "--rm", service_name, "find", directory, "-name", f"*.{file_ext}"],
                    capture_output=True, text=True, check=True
                )
                files = [f.strip() for f in result.stdout.split('\n') if f.strip()]
                
                for file_path in files:
                    print(f"\n处理文件: {file_path}")
                    command = ["cvc5", "--stats", file_path]
                    try:
                        process = subprocess.Popen(
                            ["docker-compose", "run", "--rm", service_name] + command,
                            preexec_fn=os.setsid
                        )
                        process.wait()
                        if process.returncode != 0:
                            success = False
                    except KeyboardInterrupt:
                        print("\n命令被用户中断。")
                        if process:
                            os.killpg(os.getpgid(process.pid), signal.SIGTERM)
                            process.wait()
                        success = False
                    except Exception as e:
                        print(f"命令执行失败: {e}")
                        success = False
                        
            except subprocess.CalledProcessError as e:
                print(f"错误: 无法列出目录 {directory} 中的文件: {e}")
                success = False
        
        return success
    
    else:
        print("错误: 必须指定--cvc5-file或--cvc5-category参数")
        return False

