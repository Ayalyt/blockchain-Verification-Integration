                      help='执行cipher-verification的cv_cec验证')
    parser.add_argument('--cv', action='store_true',
                      help='执行cipher-verification的cv验证')
    
    parser.add_argument('--cvc5-file', type=str, help='指定单个smt2文件路径')
    parser.add_argument('--cvc5-category', type=str, choices=['babyjub', 'mimc', 'poseidon', 'all'],
                       help='指定要处理的文件类别')
    parser.add_argument('--cv-cec-file1', type=str, help='cv_cec命令的第一个文件路径')
    parser.add_argument('--cv-cec-file2', type=str, help='cv_cec命令的第二个文件路径')
