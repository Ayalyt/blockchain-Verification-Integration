def run_performance_comparison(test_case):
    print(f"\n{'='*60}")
    print(f"  性能测试 {test_case} - 运行时间对比  ")
    print(f"{'='*60}")

    try:
        subprocess.run(
            ["docker-compose", "up", "-d", "smartifsyn-test"],
            check=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
    except subprocess.CalledProcessError:
        print("错误: 无法启动 smartifsyn-test 容器")
        return False
    
    test_case_num = test_case.replace('性能测试', '').strip()
    
    smartifsyn_module = f"compare.time_test_{test_case_num}.SmartIFSyn_time_test_{test_case_num}"
    stv_module = f"compare.time_test_{test_case_num}.STV_time_test_{test_case_num}"
    
    print(f"SmartIFSyn 脚本: {smartifsyn_module}")
    print(f"STV 脚本: {stv_module}")
    print()
    
    show_progress = test_case_num == "1"
    
    print("正在运行 SmartIFSyn 脚本...")
    smartifsyn_start = time.time()
    
    try:
        if show_progress:
            result = subprocess.run(
                ["docker-compose", "run", "--rm", "smartifsyn-test", "python3", "-m", smartifsyn_module],
                timeout=1800
            )
        else:
            result = subprocess.run(
                ["docker-compose", "run", "--rm", "smartifsyn-test", "python3", "-m", smartifsyn_module],
                capture_output=True,
                text=True,
                timeout=1800
            )
        
        smartifsyn_end = time.time()
        smartifsyn_time = smartifsyn_end - smartifsyn_start
        
        if result.returncode == 0:
            print(f"SmartIFSyn 执行成功，耗时: {smartifsyn_time:.2f} 秒")
            if not show_progress:
                for line in result.stdout.split('\n'):
                    if "SmartIFSyn average time:" in line:
                        smartifsyn_avg_time = float(line.split(':')[1].strip())
                        break
                else:
                    smartifsyn_avg_time = smartifsyn_time
            else:
                smartifsyn_avg_time = smartifsyn_time
        else:
            print(f"SmartIFSyn 执行失败，退出码: {result.returncode}")
            if not show_progress:
                print(f"错误输出: {result.stderr}")
            smartifsyn_avg_time = None
    except subprocess.TimeoutExpired:
        print("SmartIFSyn 脚本执行超时")
        smartifsyn_avg_time = None
    except Exception as e:
        print(f"SmartIFSyn 脚本执行出错: {e}")
        smartifsyn_avg_time = None
    
    print()
    
    print("正在运行 STV 脚本...")
    stv_start = time.time()
    current_pwd = os.environ.get("HOST_PROJECT_PATH") or os.getcwd()
    cmd_stv = ["docker-compose", "exec", "-T", "-e", f"HOST_PROJECT_PATH={current_pwd}",  "smartifsyn-test", "python3", "-m", stv_module]
    
    try:
        if show_progress:
            result = subprocess.run(
                cmd_stv,
                timeout=1800
            )
        else:
            result = subprocess.run(
                cmd_stv,
                capture_output=True,
                text=True,
                timeout=600
            )
        
        stv_end = time.time()
        stv_time = stv_end - stv_start
        
        if result.returncode == 0:
            if (stv_time <= 600):
                print(f"STV 执行成功，耗时: {stv_time:.2f} 秒")
                if not show_progress:
                    for line in result.stdout.split('\n'):
                        if "STV average time:" in line:
                            stv_avg_time = float(line.split(':')[1].strip())
                            break
                    else:
                        stv_avg_time = stv_time
                else:
                    stv_avg_time = stv_time
            else:
                print(f"STV 执行超时，耗时: {stv_time:.2f} 秒")
                stv_avg_time = None
        else:
            print(f"STV 执行失败，退出码: {result.returncode}")
            if not show_progress:
                print(f"错误输出: {result.stderr}")
            stv_avg_time = None
    except subprocess.TimeoutExpired:
        print("STV 脚本执行超时")
        stv_avg_time = None
    except Exception as e:
        print(f"STV 脚本执行出错: {e}")
        stv_avg_time = None
    
    
    if smartifsyn_avg_time is not None and stv_avg_time is not None:
        print(f"\n{'='*60}")
        print("  运行时间比较：  ")
        print(f"{'='*60}")
        print(f"SmartIFSyn 平均时间: {smartifsyn_avg_time:.4f} 秒")
        print(f"STV 平均时间: {stv_avg_time:.4f} 秒")
        
        if smartifsyn_avg_time < stv_avg_time:
            improvement = ((stv_avg_time - smartifsyn_avg_time) / stv_avg_time) * 100
            print(f"SmartIFSyn 比 STV 快 {improvement:.2f}%")
        else:
            improvement = ((smartifsyn_avg_time - stv_avg_time) / smartifsyn_avg_time) * 100
            print(f"STV 比 SmartIFSyn 快 {improvement:.2f}%")
    
    print(f"{'='*60}")
    
    return smartifsyn_avg_time is not None and stv_avg_time is not None

def execute_compiler_testing(args):
    # 直接运行compiler-testing脚本，不通过容器
    project_dir = os.path.dirname(os.path.abspath(__file__))
    compiler_testing_dir = os.path.join(project_dir, "compiler-testing")
    
    if not os.path.exists(compiler_testing_dir):
        print(f"错误: compiler-testing目录不存在: {compiler_testing_dir}")
        return False
    
    # 构建命令
    command = ["node", "cmd/src/main.js"]
    
    if args.compiler_testing_args:
        command.extend(args.compiler_testing_args)
    
    print(f"正在运行compiler-testing命令: {' '.join(command)}")
    print(f"工作目录: {compiler_testing_dir}")
    
    try:
        # 切换到compiler-testing目录执行命令
        original_dir = os.getcwd()
        os.chdir(compiler_testing_dir)
        
        # 检查node是否可用
        try:
            subprocess.run(["node", "--version"], check=True, capture_output=True)
        except (subprocess.CalledProcessError, FileNotFoundError):
            print("错误: Node.js未安装或不可用")
            os.chdir(original_dir)
            return False
        
        # 检查main.js是否存在
        main_js_path = os.path.join("cmd", "src", "main.js")
        if not os.path.exists(main_js_path):
            print(f"错误: 主脚本不存在: {main_js_path}")
            os.chdir(original_dir)
            return False
        
        # 执行命令
        result = subprocess.run(
            command,
            timeout=None,
            check=False,
            capture_output=False,
            text=True
        )
        
        os.chdir(original_dir)
        return result.returncode == 0
        
    except KeyboardInterrupt:
        print("\n命令被用户中断。")
        os.chdir(original_dir)
        return False
    except Exception as e:
        print(f"命令执行失败: {e}")
        os.chdir(original_dir)
        return False

def execute_generic_service(args):
    service_name = args.service
    command = args.command
    execution_mode = args.mode if args.mode else "run"
    
    if not service_name:
        print("错误: 必须指定服务名称")
        return False
    
    if not command:
        print("错误: 必须指定要执行的命令")
        return False
    
    return execute_docker_compose_command(service_name, command, execution_mode)

def main():
    parser = argparse.ArgumentParser(
        description="chainctl",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
使用示例:
  chainctl -C                    # 执行密码算法验证
  chainctl -V                    # 执行Circom编译器验证
  chainctl -V circuit.circom artifacts/  # 执行Circom编译器验证
  chainctl -V circuit.circom artifacts/ -v 2.2.0 --NC --NR
  chainctl -S file.sol ContractName
  chainctl -S file.sol ContractName -m c -d n
  chainctl -C --cvc5 --cvc5-file cipher-verification-for-CIRCOM/babyjub/babyadd/babyadd_equivalence.smt2
  chainctl -C --cvc5 --cvc5-category babyjub
  chainctl -C --cvc5 --cvc5-category all
  chainctl -C --cv-cec --cv-cec-file1 cipher-verification-for-CIRCOM/SHA-256/sha-256_ref.cl --cv-cec-file2 cipher-verification-for-CIRCOM/SHA-256/sha-256_tgt.cl
  chainctl -C --cv --cv-file cipher-verification-for-CIRCOM/SHA-256/combine_for_comparison_using_cv.cl
  chainctl --service compiler-verification --command "python3 -m RAW.Verifier.main circuit.circom artifacts/"
  chainctl --service smartifsyn-test --command "python3 script.py file.sol ContractName"
        """
    )
    
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument('-C', '--cipher', action='store_true', 
                      help='执行密码算法验证')
    group.add_argument('-V', '--compiler', action='store_true',
                      help='执行Circom编译器验证')  
    group.add_argument('-S', '--smartifsyn', action='store_true',
                      help='执行智能合约信息流分析工具')
