from contextlib import contextmanager

@contextmanager
def suppress_output():
    with open(os.devnull, 'w') as fnull:
        old_stdout, old_stderr = sys.stdout, sys.stderr
        sys.stdout, sys.stderr = fnull, fnull
        try:
            yield
        finally:
            sys.stdout, sys.stderr = old_stdout, old_stderr

def build_container(service_name):
    print(f"构建中...")
    start_time = time.time()
    try:
        result = subprocess.run(
            ["docker-compose", "build", service_name],
            check=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        end_time = time.time()
        build_time = end_time - start_time
        print(f"构建完成 (用时: {build_time:.2f}秒)")
        return True
    except subprocess.CalledProcessError as e:
        end_time = time.time()
        build_time = end_time - start_time
        print(f"[失败] {service_name} 容器构建失败 (用时: {build_time:.2f}秒): {e}")
        return False
    except FileNotFoundError:
        print("[错误] 'docker-compose' 命令未找到")
        return False

def execute_docker_compose_command(service_name, python_args, execution_mode="run"):
    if execution_mode == "run":
        command = ["docker-compose", "run", "--rm", service_name]
    elif execution_mode == "exec":
        command = ["docker-compose", "exec", service_name]
    else:
        print(f"[错误] 未知的执行模式: {execution_mode}")
        return False
    
    if isinstance(python_args, list):
        if python_args and python_args[0] not in ["python3", "/app/main.py", "script.py", "cvc5", "cv_cec", "cv", "node"]:
            if service_name == "compiler-testing" and python_args[0] == "node":
                pass
            else:
                command.append("python3")
        command.extend(python_args)
    elif isinstance(python_args, str):
        command.extend(python_args.split())
    
    print("正在运行......")
    process = None
    container_id = None
    
    try:
        if execution_mode == "run":
            container_id = get_running_container_id(service_name)

        try:
            result = subprocess.run(
                command,
                timeout=None,
                check=False,
                capture_output=False,
                text=True
            )
            return result.returncode == 0
        except KeyboardInterrupt:
            print("\n命令被用户中断。")
            return False
            
    except KeyboardInterrupt:
        print("\n命令被用户中断。")
    except subprocess.CalledProcessError as e:
        print(f"命令执行失败: {e}")
        return False
    finally:
        cleanup_resources(process, container_id, service_name)
    
    return False

def get_running_container_id(service_name):
    try:
        result = subprocess.run(
            ["docker-compose", "ps", "-q", service_name],
            capture_output=True, text=True, check=True
        )
        container_id = result.stdout.strip()
        return container_id if container_id else None
    except subprocess.CalledProcessError:
        return None

def cleanup_resources(process, container_id, service_name):
    if process and process.poll() is None:
        try:
            os.killpg(os.getpgid(process.pid), signal.SIGTERM)
            for _ in range(5):
                if process.poll() is not None:
                    break
                time.sleep(0.1)
            else:
                os.killpg(os.getpgid(process.pid), signal.SIGKILL)
                process.wait()
        except ProcessLookupError:
            pass
    
    if container_id:
        try:
            subprocess.run(
                ["docker", "stop", container_id],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=10
            )
        except (subprocess.TimeoutExpired, subprocess.CalledProcessError):
            pass
    
    try:
        subprocess.run(
            ["docker-compose", "stop", service_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=10
        )
        subprocess.run(
            ["docker-compose", "rm", "-f", service_name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=10
        )
    except (subprocess.TimeoutExpired, subprocess.CalledProcessError):
        pass
    
