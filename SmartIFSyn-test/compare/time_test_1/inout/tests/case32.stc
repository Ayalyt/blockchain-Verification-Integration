//pragma solidity ~0.4.26;

contract OddEven {
    struct Player {
        address addr;
        uint number;
    }

    Player[2] private players;
    uint count = 0;

    function play(uint keyNumber) public payable {
            require(msg.value == 1 ether, 'msg.value must be 1 eth');
            players[count] = Player(msg.sender, keyNumber);
            count++;
            if (count == 2) selectWinner();
    }

    function selectWinner() private {
            uint n = players[0].number + players[1].number;
            (bool success, bytes memory data) = players[n%2].addr.call(abi.encode(address(this).balance));
            require(success, 'transfer failed');
            delete players;
            count = 0;
    }
}
